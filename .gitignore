# ==============================================================================
# .gitignore for Academic Codex Research Projects
# ==============================================================================

# LaTeX build artifacts
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.nav
*.out
*.snm
*.toc
*.vrb
*.synctex.gz
*.run.xml
*-blx.bib

# Compiled PDFs (uncomment to track specific PDFs)
# *.pdf

# Python
__pycache__/
*.pyc
*.pyo

# R
.Rproj.user/
.Rhistory
.RData
.Rdata

# OS files
.DS_Store
Thumbs.db

# Legacy Claude local files (not shared across machines)
.claude/settings.local.json
.claude/state/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Quarto rendering artifacts
/.quarto/
**/*.quarto_ipynb

# Output artifacts — uncomment lines below based on your preference
# *.rds
# output/**/*.rds
docs/

**/*.quarto_ipynb
